# /etc/dnsmasq.d/lab.conf — managed by Ansible
domain={{ lab_domain }}
local=/{{ lab_domain }}/

# --- Upstream DNS forwarders ---
# no-resolv prevents dnsmasq reading /run/dnsmasq/resolv.conf (which
# doesn't exist since we disabled systemd-resolved). Upstream servers
# are defined explicitly below.
no-resolv
{% for server in gateway_upstream_dns %}
server={{ server }}
{% endfor %}

# --- DNS Records (host-record creates both A and PTR records) ---
{% for record in gateway_dns_records %}
host-record={{ record.hostname }}.{{ lab_domain }},{{ record.ip }}
{% endfor %}

# --- DHCP on management network (native/untagged on trunk) ---
interface={{ gateway_vlan_trunk_nic }}
dhcp-range={{ lab_mgmt_prefix }}.100,{{ lab_mgmt_prefix }}.199,255.255.255.0,12h
dhcp-option=option:router,{{ lab_gateway }}
dhcp-option=option:dns-server,{{ lab_dns_server }}
dhcp-option=option:ntp-server,{{ lab_ntp_servers | join(',') }}

# Static MAC→IP reservations (skips placeholder MACs until real ones are set)
{% for res in gateway_dhcp_reservations %}
{% if 'xx' not in res.mac %}
dhcp-host={{ res.mac }},{{ res.hostname }},{{ res.ip }}
{% endif %}
{% endfor %}
