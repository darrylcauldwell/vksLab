# /etc/netplan/01-lab.yaml — managed by Ansible
network:
  version: 2
  ethernets:
    {{ gateway_public_nic }}:
      dhcp4: true
    {{ gateway_vlan_trunk_nic }}:
      mtu: 9000
      nameservers:
        addresses:
          - 127.0.0.1
  vlans:
{% for iface in gateway_vlan_interfaces %}
    {{ gateway_vlan_trunk_nic }}.{{ iface.vlan }}:
      id: {{ iface.vlan }}
      link: {{ gateway_vlan_trunk_nic }}
      addresses:
        - {{ iface.ip }}
      mtu: {{ iface.mtu }}
{% endfor %}
